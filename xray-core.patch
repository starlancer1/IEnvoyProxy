diff -Naur a/core/domain2ip.go b/core/domain2ip.go
--- a/core/domain2ip.go	1970-01-01 00:00:00.000000000 +0000
+++ b/core/domain2ip.go	2026-02-23 16:54:12.830250167 +0000
@@ -0,0 +1,40 @@
+package core
+
+import (
+	"sync"
+)
+
+// DomainToIPs is a map of domain names to IP addresses
+// Note: there may be multiple IP addresses for a given domain
+var DomainToIPs = map[string][]string{}
+var domainMutex sync.RWMutex
+
+// GetDomainIPs returns IP addresses for a given domain
+func GetDomainIPs(domain string) ([]string, bool) {
+	domainMutex.RLock()
+	defer domainMutex.RUnlock()
+	ips, ok := DomainToIPs[domain]
+	return ips, ok
+}
+
+// SetDomainIPs sets IP addresses for a given domain
+func SetDomainIPs(domain string, ips []string) {
+	domainMutex.Lock()
+	defer domainMutex.Unlock()
+	DomainToIPs[domain] = ips
+}
+
+// DropDomainIPs drops specific IP address for a given domain from the cache
+func DropDomainIPs(domain string, ip string) {
+	domainMutex.Lock()
+	defer domainMutex.Unlock()
+	for i, existingIP := range DomainToIPs[domain] {
+		if existingIP == ip {
+			DomainToIPs[domain] = append(DomainToIPs[domain][:i], DomainToIPs[domain][i+1:]...)
+			if len(DomainToIPs[domain]) == 0 {
+				delete(DomainToIPs, domain)
+			}
+			break
+		}
+	}
+}
diff -Naur a/envoy/xray.go b/envoy/xray.go
--- a/envoy/xray.go	1970-01-01 00:00:00.000000000 +0000
+++ b/envoy/xray.go	2026-04-27 11:54:21.346086194 +0000
@@ -0,0 +1,267 @@
+package xray
+
+// copied and modified from main/commands/run.go
+
+// feeding core.LoadConfig with a string reader containing the config
+// JSON seems the simplest way to run xray as a library
+//
+// Golang's JSON support seems a little cumbersome for a couple
+// string substitutions in a complex JSON snippet, so we just
+// use fmt.Sprintf to assemble the config
+//
+// The JSON file we build should look similar to the client example config
+// (that will be) documented here:
+// https://gitlab.com/stevenmcdonald/envoy-proxy-examples/v2ray/
+
+// We provide functions for starting and stopping several client services
+// independently. Unfortunately you can't start them all and tell xray to
+// use the one that works... but that's what Envoy is good at.
+
+import (
+	"fmt"
+	"strings"
+	"sync"
+
+	core "github.com/xtls/xray-core/core"
+	_ "github.com/xtls/xray-core/main/distro/all"
+)
+
+const jsonV5 = "json"
+
+var xrxhServers sync.Map
+
+// getInbound
+//
+// @param port - port to listen for SOCKS5 connections
+func getInbound(clientPort int) string {
+	return fmt.Sprintf(`
+      {
+        "port": %d,
+        "protocol": "socks",
+        "sniffing": {
+          "enabled": true,
+          "destOverride": ["http", "tls"]
+        },
+        "settings": {}
+      }`, clientPort)
+}
+
+func getXrxhConfig(clientPort int, serverAddress, serverPort, xhttpPath, id string, allowInsecure bool, serverName string, hostName string, xhttpMode string, xhttpVersion string) string {
+	if xhttpVersion == "h2" {
+		return fmt.Sprintf(`
+  {
+    "log": {
+      "access": "none",
+      "loglevel": "warning"
+    },
+    "inbounds": [ %s ],
+    "outbounds": [
+      {
+        "protocol": "vless",
+        "settings": {
+          "vnext": [
+            {
+              "address": "%s",
+              "port": %s,
+              "users": [
+                {
+                  "id": "%s",
+                  "encryption": "none"
+                }
+              ]
+            }
+          ]
+        },
+        "streamSettings": {
+          "network": "xhttp",
+          "xhttpSettings": {
+            "host": "%s",
+            "path": "%s",
+            "mode": "%s"
+          },
+          "security": "tls",
+          "tlsSettings": {
+            "serverName": "%s",
+            "allowInsecure": %t,
+            "alpn": [ "h2", "http/1.1"]
+          }
+        }
+      }
+    ]
+  }`, getInbound(clientPort), serverAddress, serverPort, id, hostName, xhttpPath, xhttpMode, serverName, allowInsecure)
+	} else if xhttpVersion == "h3" {
+		return fmt.Sprintf(`
+  {
+    "log": {
+      "access": "none",
+      "loglevel": "warning"
+    },
+    "inbounds": [ %s ],
+    "outbounds": [
+      {
+        "protocol": "vless",
+        "settings": {
+          "vnext": [
+            {
+              "address": "%s",
+              "port": %s,
+              "users": [
+                {
+                  "id": "%s",
+                  "encryption": "none"
+                }
+              ]
+            }
+          ]
+        },
+        "streamSettings": {
+          "network": "xhttp",
+          "xhttpSettings": {
+            "host": "%s",
+            "path": "%s",
+            "mode": "%s",
+			"#xmux": { //Use default values. To customize: remove the preceding # (hash). Note: cannot exceed Nginx's maximum (upper limit) value.
+				"maxConcurrency": 128, //Nginx default limit 128. https://nginx.org/en/docs/http/ngx_http_v3_module.html#http3_max_concurrent_streams
+				"hMaxRequestTimes": 1000, //Nginx default limit 1000. https://nginx.org/en/docs/http/ngx_http_core_module.html#keepalive_requests
+				"hMaxReusableSecs": 3600 //Nginx default limit 3600s(1h). https://nginx.org/en/docs/http/ngx_http_core_module.html#keepalive_time
+			},
+			"#downloadSettings": { //For H2 download: remove the preceding # (hash) to use downloadSettings; change the mode above and in server.json to stream-up.
+				"address": "%s",
+				"port": %s,
+				"network": "xhttp",
+				"xhttpSettings": {
+					"host": "%s",
+					"path": "%s", //Fill in your path (same as above)
+					"#xmux": { //Use default values. To customize: remove the preceding # (hash). Note: cannot exceed Nginx's maximum (upper limit) value.
+						"maxConcurrency": 128, //Nginx default limit 128. https://nginx.org/en/docs/http/ngx_http_v3_module.html#http3_max_concurrent_streams
+						"hMaxRequestTimes": 1000, //Nginx default limit 1000. https://nginx.org/en/docs/http/ngx_http_core_module.html#keepalive_requests
+						"hMaxReusableSecs": 3600 //Nginx default limit 3600s(1h). https://nginx.org/en/docs/http/ngx_http_core_module.html#keepalive_time
+					}
+				},
+				"security": "tls",
+				"tlsSettings": {
+					"serverName": "%s",
+					"allowInsecure": %t,
+					"alpn": ["h2", "http/1.1"]
+				}
+			}
+		  },
+          "security": "tls",
+          "tlsSettings": {
+            "serverName": "%s",
+            "allowInsecure": %t,
+            "alpn": [
+			  "h3" //If performance is far below expectations and the log shows "QUIC flood detected", refer to: https://github.com/XTLS/Xray-core/discussions/4197
+			]
+          }
+        }
+      }
+    ]
+  }`, getInbound(clientPort), serverAddress, serverPort, id, hostName, xhttpPath, xhttpMode, serverAddress, serverPort, hostName, xhttpPath, serverName, allowInsecure, serverName, allowInsecure)
+	} else {
+		return ""
+	}
+}
+
+func startServer(jsonConfig string) (*core.Instance, error) {
+	// fmt.Printf("DEBUG: Starting Xray with JSON config:\n%s\n", jsonConfig)
+	reader := strings.NewReader(jsonConfig)
+
+	config, err := core.LoadConfig(jsonV5, reader)
+	if err != nil {
+		fmt.Printf("error reading config: %s\n", err)
+		return nil, err
+	}
+
+	server, err := core.New(config)
+	if err != nil {
+		fmt.Printf("error creating server: %s\n", err)
+		return nil, err
+	}
+
+	if err := server.Start(); err != nil {
+		fmt.Printf("failed to start %s\n", err)
+
+		_ = server.Close()
+
+		return nil, err
+	}
+
+	return server, nil
+}
+
+// XrxhConfigOptional holds optional configuration for Xrxh connections
+type XrxhConfigOptional struct {
+	AllowInsecure bool
+	ServerName    string
+	Hostname      string
+	XhttpMode     string
+	XhttpVersion  string
+}
+
+// StartXrxh - start Xray with XHTTP transport via HTTP/2 or HTTP/1.1
+//
+// @param clientPort - client SOCKS port routed to the XHTTP server
+//
+// @param serverAddress - IP or hostname of the server
+//
+// @param serverPort - port of the XHTTP server (probably 443)
+//
+// @param xhttpPath - path to the XHTTP endpoint on the server
+//
+// @param id - UUID used to authenticate with the server
+//
+// @param config - optional configuration with certain defaults
+//
+// @returns error, if transport could not be started, or `nil` on success.
+func StartXrxh(clientPort int, serverAddress, serverPort, xhttpPath, id string, config ...XrxhConfigOptional) error {
+	// Set defaults for optional config
+	allowInsecure := false
+	serverName := serverAddress
+	hostName := serverAddress
+	// Defaults to HTTP/2
+	xhttpMode := "stream-one"
+	xhttpVersion := "h2"
+
+	// Override with provided config if any
+	if len(config) > 0 {
+		cfg := config[0]
+		allowInsecure = cfg.AllowInsecure
+		if cfg.ServerName != "" {
+			serverName = cfg.ServerName
+		}
+		if cfg.Hostname != "" {
+			hostName = cfg.Hostname
+		}
+		if cfg.XhttpMode != "" {
+			// Can be either stream-one (for h2) or packet-up (for h3)
+			xhttpMode = cfg.XhttpMode
+		}
+		if cfg.XhttpVersion != "" {
+			// Can be either h2 or h3
+			xhttpVersion = cfg.XhttpVersion
+		}
+	}
+
+	server, err := startServer(getXrxhConfig(clientPort, serverAddress, serverPort, xhttpPath, id, allowInsecure, serverName, hostName, xhttpMode, xhttpVersion))
+	if err != nil {
+		return err
+	}
+
+	xrxhServers.Store(clientPort, server)
+	return nil
+}
+
+func StopXrxhByPort(clientPort int) {
+	if val, ok := xrxhServers.LoadAndDelete(clientPort); ok {
+		_ = val.(*core.Instance).Close()
+	}
+}
+
+func StopXrxh() {
+	xrxhServers.Range(func(key, value any) bool {
+		xrxhServers.Delete(key)
+		_ = value.(*core.Instance).Close()
+		return true
+	})
+}
