+// Close shuts down the DNSPacketConn and the underlying transport.
+// It signals the sendLoop to exit immediately (via the done channel) and
+// closes the transport (e.g. HTTPPacketConn) so that its in-flight HTTP
+// requests are cancelled and its internal goroutines terminate promptly.
+func (c *DNSPacketConn) Close() error {
+	c.closeOnce.Do(func() { close(c.done) })
+	_ = c.transport.Close()
+	return c.QueuePacketConn.Close()
+}
